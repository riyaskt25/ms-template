  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "companyId", "value": "1" },
    { "key": "salesmanId", "value": "1" },
    { "key": "adminUserId", "value": "1" }
  ],
  "item": [
    {
      "name": "Company",
      "item": [
        {
          "name": "Get All Companies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/companies",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies"]
            }
          }
        },
        {
          "name": "Get Company By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/companies/{{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "{{companyId}}"]
            }
          }
        },
        {
          "name": "Create Company",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registrationNumber\": \"REG-NEW-1002\",\n  \"emailAddress\": \"company@snb.com\",\n  \"mobileNumber\": \"+971500000001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/companies",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies"]
            }
          }
        },
        {
          "name": "Update Company",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registrationNumber\": \"REG-100001\",\n  \"emailAddress\": \"company-updated@snb.com\",\n  \"mobileNumber\": \"+971500000002\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/companies/{{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "{{companyId}}"]
            }
          }
        },
        {
          "name": "Soft Delete Company",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/companies/{{companyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "{{companyId}}"]
            }
          }
        }
      ]
    },
